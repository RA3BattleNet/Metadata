<?xml version="1.0" encoding="UTF-8"?>
<Metadata>
    <Tags>
        <!-- 预留标记 -->
        <Commit>${TIMESTAMP}</Commit>
    </Tags>
    <Includes>
        <!-- 子模块 -->
        <Include Source="changelogs/changelogs.xml" Type="private" />
        <Include Source="manifests/manifests.xml" Type="private" />
        <Include Source="posts/posts.xml" Type="private" />
    </Includes>

    <!-- 资源注册 -->
    <!-- 图片在编译时会自动变成WebP格式 -->
    <!-- 网页图片需要使用Url -->

    <Image ID="corona-icon-64px" Source="images/icon-64px.png" />
    <Image ID="corona-logo-colored" Source="images/logo-colored.png" />
    <Image ID="corona-logo-example" Url="https://cor-games.com/images/corona-mainpage-logo.png" />

    <!-- 日冕Mod -->
    <Mod ID="Corona">

        <!-- 基本属性 -->
        <CurrentVersion>3.229</CurrentVersion>
        <Icon>corona-icon-64px</Icon>

        <!-- 主页面 -->
        <Style>
            <Logo Width="400" Height="80">corona-logo-colored</Logo>
            <!-- 控件样式 -->
            <Controls>
                <LaunchButton>
                    <BorderBrush>#FF000000</BorderBrush>
                </LaunchButton>
                <Label>
                    <FontSize>14</FontSize>
                    <ForegroundBrush>#FFFFFFFF</ForegroundBrush>
                </Label>
            </Controls>
            <!-- 背景图片 -->
            <Background Random="true">
                <Image>background-1</Image>
                <Image>background-2</Image>
                <Image>background-3</Image>
                <Image>background-4</Image>
                <Image>background-5</Image>
            </Background>
        </Style>

        <!-- 版本数据 -->
        <Packages>
            <Package Version="3.229">
                <ReleaseDate>2025-04-01</ReleaseDate>
                <Changelogs>
                    <Changelog Language="zh-CN">changelog-zh-3229</Changelog>
                    <Changelog Language="en-US">changelog-en-3229</Changelog>
                </Changelogs>
                <Manifest>manifest-3229</Manifest>
            </Package>
            <Package Version="3.228">
                <ReleaseDate>2025-03-28</ReleaseDate>
                <Changelogs>
                    <Changelog Language="zh-CN">changelog-zh-3228</Changelog>
                    <Changelog Language="en-US">changelog-en-3228</Changelog>
                </Changelogs>
                <Manifest>manifest-3228</Manifest>
            </Package>
        </Packages>

        <!-- 新闻 -->
        <Posts>
            <Post DateTime="2025-04-01T00:00:00+08:00">
                <Titles>
                    <Title Language="zh-CN">版本更新 3.229</Title>
                    <Title Language="en-US">Update 3.229</Title>
                </Titles>
                <Contents>
                    <Content Language="zh-CN">news-zh-3229</Content>
                    <Content Language="en-US">news-en-3229</Content>
                </Contents>
            </Post>
        </Posts>
    </Mod>

</Metadata>